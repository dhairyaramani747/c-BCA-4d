using System;

namespace Factorial
{
    class factorial
    {
        static void Main(string[] args)
        {
            int a;

            Console.WriteLine("Enter The Number :");
            
              a = Convert.ToInt32(Console.ReadLine());

            long fact = 1;

            for (int i = 1; i <= a; i++)
            {
                fact *= i;
            }

            if (a == 0)
            {
                Console.WriteLine(" factorial not working with zero");
                return;
            }
            Console.WriteLine("Factorial of " + a + " is: " + fact);
        }
    }
}
