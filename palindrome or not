using System;

class Program
{
    static void Main()
    {
        Console.Write("Enter a number: ");
        string number = Console.ReadLine();

        string reversed = "";

        for (int i = number.Length - 1; i >= 0; i--)
        {
            reversed += number[i];
        }

        if (number == reversed)
        {
            Console.WriteLine("number is palindrome.");
        }
        else
        {
            Console.WriteLine("number is not palindrome.");
        }
    }
}
