using System;

class Program
{
    static void Main()
    {
        int max;

        Console.Write("enter number 1: ");
        max = Convert.ToInt32(Console.ReadLine());

        for (int i = 2; i <= 5; i++)
        {
            Console.Write("enter number " + i + ": ");
            int num = Convert.ToInt32(Console.ReadLine());

            if (num > max)
            {
                max = num;
            }
        }

        Console.WriteLine("meximum is: " + max);
    }
}
