using System;

class Program
{
    static void Main()
    {
        string password;
        bool isValid = false;

        do
        {
            Console.Write("ENTER YOUR PASSWORD: ");
            password = Console.ReadLine();

            isValid = ValidatePassword(password);

            if (!isValid)
            {
                Console.WriteLine("Password must:");

                Console.WriteLine("- Be at least 8 characters long");

                Console.WriteLine("- Contain at least one uppercase letter");

                Console.WriteLine("- Contain at least one lowercase letter");

                Console.WriteLine("- Contain at least one digit");

                Console.WriteLine("- Contain at least one special character");

                Console.WriteLine();
            }

        } while (!isValid);

        Console.WriteLine("Password accepted!");
    }

    static bool ValidatePassword(string password)
    {
        if (string.IsNullOrEmpty(password) || password.Length < 8)
            return false;

        bool hasUpper = password.Any(char.IsUpper);
        bool hasLower = password.Any(char.IsLower);
        bool hasDigit = password.Any(char.IsDigit);
        bool hasSpecial = password.Any(ch => !char.IsLetterOrDigit(ch));

        return hasUpper && hasLower && hasDigit && hasSpecial;
    }
}
